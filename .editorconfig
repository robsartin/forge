# EditorConfig helps maintain consistent coding styles across editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{xml,html}]
indent_size = 4

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[pom.xml]
indent_size = 4
